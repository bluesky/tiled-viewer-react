    "@visx/mock-data": "^3.12.0",
    "@visx/pattern": "^3.12.0",
    "@visx/react-spring": "^3.12.0",
    "@visx/responsive": "^3.12.0",
    "@visx/scale": "^3.12.0",
    "@visx/shape": "^3.12.0",
    "@visx/tooltip": "^3.12.0",
