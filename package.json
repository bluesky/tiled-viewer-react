    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "eslint-plugin-storybook": "^0.11.2",
    "gh-pages": "^6.3.0",
    "globals": "^15.13.0",
    "jsdom": "^26.1.0",
    "msw": "^2.8.4",
    "msw-storybook-addon": "^2.0.4",
    "postcss": "^8.4.49",
