{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "declaration": true,
    "skipLibCheck": true,
     "esModuleInterop": true ,
     "declarationMap": true,
    "baseUrl": ".",
     "paths": {
      //"react-vite-library": [ "src/components/index.ts" ],
      "react-vite-library": [ "src/index.ts" ],
      "@/*": ["./src/*"]
    },
    "typeRoots": [
      "node_modules/@types",
      //"src/component/index.d.ts"
      "src/index.d.ts"
    ]
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}